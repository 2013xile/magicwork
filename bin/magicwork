#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync, spawn } = require('child_process');

const DEFAULT_SOCKET = 'unix:/tmp/kitty.sock';
const TEMPLATE_TASK_COUNT = 5;
const CONFIG_FILE = 'config.json';
const ACTIVE_STATE_FILE = '.magicwork-active.json';
const RECORDS_DIR = 'records';
const CODEX_NOTIFY_SCRIPT = path.join(__dirname, 'codex_notify.py');
const CODEX_WATCHER_SCRIPT = path.join(__dirname, 'kitty_codex_watcher.py');
const CODEX_SESSION_SCRIPT = path.join(__dirname, 'codex_session.sh');
const REGISTER_SESSION_SCRIPT = path.join(__dirname, 'register_codex_session.js');
const EXAMPLE_HOOK_SCRIPT = 'hooks/project-lifecycle.example.sh';

main();

function main() {
  const parsed = extractGlobalOptions(process.argv.slice(2));
  const args = parsed.args;
  const globalOptions = parsed.options;
  const command = args[0];
  const commandArgs = [...args.slice(1), ...globalOptions];

  try {
    switch (command) {
      case 'init':
        runInit(commandArgs, { defaultCount: TEMPLATE_TASK_COUNT });
        break;
      case 'add':
        runInit(commandArgs, { defaultCount: 1 });
        break;
      case 'run':
        runLaunch(commandArgs);
        break;
      case 'restore':
        runRestore(commandArgs);
        break;
      case 'clean':
        runClean(commandArgs);
        break;
      case 'finish':
        runFinish(commandArgs);
        break;
      case 'report':
        runReport(commandArgs);
        break;
      case 'sync':
        runSync(commandArgs);
        break;
      case 'config':
        runConfig(commandArgs);
        break;
      case 'record-session':
        runRecordSession(commandArgs);
        break;
      case 'help':
      case '--help':
      case '-h':
      case undefined:
        printHelp();
        break;
      default:
        fail(`Unsupported command: ${command}`);
    }
  } catch (error) {
    fail(error.message || String(error));
  }
}

function extractGlobalOptions(argv) {
  const options = [];
  const args = [...argv];

  while (args.length > 0) {
    const token = args[0];
    if (token !== '--os-root') {
      break;
    }
    if (args.length < 2) {
      fail('--os-root requires a value');
    }
    options.push(args.shift(), args.shift());
  }

  return { args, options };
}

function runInit(args, { defaultCount = TEMPLATE_TASK_COUNT } = {}) {
  const options = parseOptions(args);
  const date = options.date || todayLocal();
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const dayDir = path.join(project.recordsDir, date);
  ensureDir(dayDir);
  ensureDir(tasksDir(dayDir));
  const defaultRepo = options.defaultRepo || project.defaultRepo || '';
  const defaultBaseBranch = defaultRepo ? (detectCurrentBranch(defaultRepo) || 'main') : 'main';
  const activeTasks = options.noCarryActive ? [] : readActiveTasks(project.osRoot);
  const existingCards = listTaskCardFiles(dayDir);
  const nextIndexStart = existingCards.length + 1;
  const requestedCount = resolveInitCardCount(options);
  const cardCount = requestedCount || (existingCards.length ? defaultCount : Math.max(defaultCount, activeTasks.length));
  const createdFiles = createTaskCards({
    dayDir,
    startIndex: nextIndexStart,
    count: cardCount,
    activeTasks,
    date,
    defaultRepo,
    defaultBaseBranch,
  });
  const indexPath = writeDayIndex(dayDir, date, project.osRoot);
  for (const filePath of createdFiles) {
    console.log(filePath);
  }
  console.log(indexPath);
}

function resolveInitCardCount(options) {
  const raw = options.count ?? options._[0];
  if (raw == null || raw === '') {
    return 0;
  }
  if (!/^\d+$/.test(String(raw))) {
    fail(`Invalid task count: ${raw}`);
  }
  const count = Number(raw);
  if (count <= 0) {
    fail(`Task count must be greater than 0: ${raw}`);
  }
  return count;
}

function runLaunch(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const rawArgs = [...options._];
  const firstArg = rawArgs[0] ? path.resolve(rawArgs[0]) : '';
  const hasExplicitInputPath = !!firstArg && fs.existsSync(firstArg) && !!inferDayDirFromTaskPath(firstArg);
  const targetArgs = hasExplicitInputPath ? rawArgs.slice(1) : rawArgs;
  let inputPath = hasExplicitInputPath
    ? firstArg
    : resolveDefaultTaskFile(options.date, project.recordsDir);
  if (!fs.existsSync(inputPath)) {
    fail(`Task file not found: ${inputPath}`);
  }

  const dayDir = inferDayDirFromTaskPath(inputPath);
  if (dayDir) {
    inputPath = writeDayIndex(dayDir, path.basename(dayDir), project.osRoot);
  }

  const content = fs.readFileSync(inputPath, 'utf8');
  const context = parseTaskFile(content, inputPath, project);
  if (!context.tasks.length) {
    fail(`No runnable tasks found in ${inputPath}`);
  }

  const socketAddress = resolveKittySocket(options.socket);
  if (!options.dryRun) {
    ensureProjectDirs(project, { os: true, code: true });
    ensureKittyServer(socketAddress);
  }

  const allResolvedTasks = context.tasks.map((task) => resolveTask(context, task));
  const selectedTasks = targetArgs.length ? resolveRunTargets(allResolvedTasks, targetArgs) : allResolvedTasks;
  const activeBranches = new Set(readActiveTasks(project.osRoot).map((task) => task.newBranch));
  const tasksToLaunch = options.rerunLaunched
    ? selectedTasks
    : selectedTasks.filter((task) => !activeBranches.has(task.newBranch));
  const skippedTasks = options.rerunLaunched
    ? []
    : selectedTasks.filter((task) => activeBranches.has(task.newBranch));

  if (!tasksToLaunch.length) {
    console.log(`run: using ${inputPath}`);
    console.log('run: no new tasks to launch');
    for (const task of skippedTasks) {
      console.log(`run: skipped already launched task ${task.index} ${task.name}`);
    }
    return;
  }

  const launched = [];
  for (const resolved of tasksToLaunch) {
    if (!options.dryRun) {
      if (resolved.status === 'todo') {
        updateTaskCardStatus(resolved.taskFilePath, 'doing');
        resolved.status = 'doing';
      }
      ensureWorktree(resolved);
      launchKittyTab(resolved, socketAddress, project, { sendPrompt: true, trigger: 'run' });
    }
    launched.push(resolved);
  }

  for (const task of launched) {
    console.log(`${task.index}. ${task.name}`);
    console.log(`   repo: ${task.repo}`);
    console.log(`   base: ${task.baseBranch}`);
    console.log(`   branch: ${task.newBranch}`);
    console.log(`   worktree: ${task.worktreePath}`);
    if (options.dryRun) {
      console.log('   mode: dry-run');
    }
  }

  for (const task of skippedTasks) {
    console.log(`${task.index}. ${task.name}`);
    console.log(`   branch: ${task.newBranch}`);
    console.log(`   worktree: ${task.worktreePath}`);
    console.log('   status: skipped already launched');
  }

  if (!options.dryRun) {
    upsertActiveTasks(project.osRoot, launched, context.date);
    writeDayIndex(context.recordsDayDir, context.date, project.osRoot);
  }
}

function resolveRunTargets(tasks, rawTargets) {
  if (!rawTargets.length) {
    return tasks;
  }
  return resolveCleanTargets(tasks, rawTargets);
}

function runClean(args) {
  const options = parseOptions(args);
  if (options.noSummary) {
    fail('clean does not support --no-summary; use finish --no-summary if you want cleanup without summary');
  }
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const inputPath = options._[0] && options._[0].endsWith('.md')
    ? path.resolve(options._.shift())
    : resolveDefaultTaskFile(options.date, project.recordsDir);

  if (!fs.existsSync(inputPath)) {
    fail(`Task file not found: ${inputPath}`);
  }

  const content = fs.readFileSync(inputPath, 'utf8');
  const context = parseTaskFile(content, inputPath, project);
  const tasks = context.tasks.map((task) => resolveTask(context, task));

  if (!tasks.length) {
    fail(`No runnable tasks found in ${inputPath}`);
  }

  const targets = options.all ? tasks : resolveCleanTargets(tasks, options._);
  if (!targets.length) {
    fail('No matching worktrees to clean');
  }

  console.log(`clean: using ${inputPath}`);
  console.log(`clean: matched ${targets.length} task(s)`);
  for (const task of targets) {
    if (options.dryRun) {
      console.log(`${task.index}. ${task.name}`);
      console.log(`   branch: ${task.newBranch}`);
      console.log(`   worktree: ${task.worktreePath}`);
      console.log('   mode: dry-run');
      continue;
    }

    ensureProjectDirs(project, { os: true, records: true });
    console.log(`clean: start task ${task.index} ${task.name}`);
    if (taskAllowsHook(task, 'onClean')) {
      runLifecycleHook(project.hooks.onClean, 'onClean', task, { logger: console.log });
    }
    console.log(`clean: removing worktree ${task.worktreePath}`);
    removeWorktreeAndBranch(task, logCleanStep);
    console.log(`clean: removing active state ${task.newBranch}`);
    removeActiveTasks(project.osRoot, [task.newBranch]);
    console.log(`clean: finished task ${task.index} ${task.name}`);
    console.log(`${task.index}. ${task.name}`);
    console.log(`   removed branch: ${task.newBranch}`);
    console.log(`   removed worktree: ${task.worktreePath}`);
  }

  if (!options.dryRun) {
    writeDayIndex(context.recordsDayDir, context.date, project.osRoot);
  }
}

function runFinish(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const inputPath = options._[0] && options._[0].endsWith('.md')
    ? path.resolve(options._.shift())
    : resolveDefaultTaskFile(options.date, project.recordsDir);

  if (!fs.existsSync(inputPath)) {
    fail(`Task file not found: ${inputPath}`);
  }

  const content = fs.readFileSync(inputPath, 'utf8');
  const context = parseTaskFile(content, inputPath, project);
  const tasks = context.tasks.map((task) => resolveTask(context, task));

  if (!tasks.length) {
    fail(`No runnable tasks found in ${inputPath}`);
  }

  const targets = options.all ? tasks : resolveCleanTargets(tasks, options._);
  if (!targets.length) {
    fail('No matching worktrees to finish');
  }

  console.log(`finish: using ${inputPath}`);
  console.log(`finish: matched ${targets.length} task(s)`);
  for (const task of targets) {
    const summaryPath = taskSummaryPath(task);
    if (options.dryRun) {
      console.log(`${task.index}. ${task.name}`);
      console.log(`   summary: ${summaryPath}`);
      console.log(`   status: done`);
      console.log(`   branch: ${task.newBranch}`);
      console.log(`   worktree: ${task.worktreePath}`);
      console.log('   mode: dry-run');
      continue;
    }

    ensureProjectDirs(project, { os: true, records: true });
    console.log(`finish: start task ${task.index} ${task.name}`);
    if (options.noSummary) {
      console.log('finish: skip summary, --no-summary');
    } else if (hasSummaryContext(task)) {
      console.log(`finish: writing summary ${summaryPath}`);
      const summaryMarkdown = generateTaskSummary(task);
      appendTaskSummary(summaryPath, task, summaryMarkdown);
    } else {
      console.log(`finish: skip summary, no usable worktree or session record`);
    }
    console.log(`finish: marking task done ${task.taskFilePath}`);
    updateTaskCardStatus(task.taskFilePath, 'done');
    if (taskAllowsHook(task, 'onClean')) {
      runLifecycleHook(project.hooks.onClean, 'onClean', task, { logger: console.log });
    }
    console.log(`finish: removing worktree ${task.worktreePath}`);
    removeWorktreeAndBranch(task, (message) => console.log(message.replace(/^clean:/, 'finish:')));
    console.log(`finish: removing active state ${task.newBranch}`);
    removeActiveTasks(project.osRoot, [task.newBranch]);
    console.log(`finish: finished task ${task.index} ${task.name}`);
  }

  if (!options.dryRun) {
    writeDayIndex(context.recordsDayDir, context.date, project.osRoot);
  }
}

function runRestore(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  const socketAddress = resolveKittySocket(options.socket);
  const activeTasks = readActiveTasks(project.osRoot);

  if (!activeTasks.length) {
    console.log('restore: no active tasks');
    return;
  }

  const resolvedActiveTasks = [];
  for (let index = 0; index < activeTasks.length; index += 1) {
    const activeTask = activeTasks[index];
    const worktreePath = findWorktreePathByBranch(activeTask.repo, activeTask.newBranch);
    resolvedActiveTasks.push({
      index: index + 1,
      name: activeTask.name,
      repo: activeTask.repo,
      baseBranch: activeTask.baseBranch || detectCurrentBranch(activeTask.repo) || 'main',
      newBranch: activeTask.newBranch,
      hookEvents: Array.isArray(activeTask.hookEvents) ? activeTask.hookEvents : defaultTaskHookEvents(),
      sessionId: activeTask.sessionId || '',
      prompt: activeTask.prompt,
      slug: slugify(activeTask.name, index + 1),
      date: activeTask.lastDate || todayLocal(),
      recordsDayDir: path.join(project.recordsDir, activeTask.lastDate || todayLocal()),
      osRoot: project.osRoot,
      worktreePath,
    });
  }

  const targets = options.all || !options._.length
    ? resolvedActiveTasks
    : resolveCleanTargets(resolvedActiveTasks, options._);

  if (!targets.length) {
    console.log('restore: no matching worktrees to reopen');
    return;
  }

  if (!options.dryRun) {
    ensureKittyServer(socketAddress);
  }

  const restored = [];
  for (const task of targets) {
    if (!task.worktreePath) {
      console.log(`restore: skipped ${task.name} (${task.newBranch}), worktree not found`);
      continue;
    }
    if (!options.dryRun) {
      launchKittyTab(task, socketAddress, project, {
        sendPrompt: false,
        trigger: 'restore',
      });
    }
    restored.push(task);
  }

  if (!restored.length) {
    console.log('restore: no matching worktrees to reopen');
    return;
  }

  for (const task of restored) {
    console.log(`${task.index}. ${task.name}`);
    console.log(`   branch: ${task.newBranch}`);
    console.log(`   worktree: ${task.worktreePath}`);
    if (options.dryRun) {
      console.log('   mode: dry-run');
    }
  }
}

function runReport(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const inputPath = options._[0] && options._[0].endsWith('.md')
    ? path.resolve(options._.shift())
    : resolveDefaultTaskFile(options.date, project.recordsDir);

  if (!fs.existsSync(inputPath)) {
    fail(`Task file not found: ${inputPath}`);
  }

  const content = fs.readFileSync(inputPath, 'utf8');
  const context = parseTaskFile(content, inputPath, project);
  const tasks = context.tasks.map((task) => resolveTask(context, task));

  if (!tasks.length) {
    fail(`No runnable tasks found in ${inputPath}`);
  }

  const targets = options.all ? tasks : resolveCleanTargets(tasks, options._);
  if (!targets.length) {
    fail('No matching worktrees to report');
  }

  for (const task of targets) {
    const recordPath = taskRecordPath(project.recordsDir, task);
    if (options.dryRun) {
      console.log(`${task.index}. ${task.name}`);
      console.log(`   record: ${recordPath}`);
      console.log(`   worktree: ${task.worktreePath}`);
      console.log('   mode: dry-run');
      continue;
    }

    ensureProjectDirs(project, { records: true, os: true });
    if (!hasSummaryContext(task)) {
      console.log(`${task.index}. ${task.name}`);
      console.log('   skip: no usable worktree or session record');
      continue;
    }

    ensureDir(path.dirname(recordPath));
    const reportMarkdown = generateTaskReport(task);
    appendTaskRecord(recordPath, task, reportMarkdown);
    updateActiveTaskSummary(project.osRoot, task.newBranch, reportMarkdown);

    console.log(`${task.index}. ${task.name}`);
    console.log(`   record: ${recordPath}`);
    console.log(`   worktree: ${task.worktreePath}`);
  }
}

function runSync(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true });
  const date = options.date || todayLocal();
  const dayDir = path.join(project.recordsDir, date);
  if (!fs.existsSync(dayDir)) {
    fail(`Date directory not found: ${dayDir}`);
  }

  const indexPath = writeDayIndex(dayDir, date, project.osRoot);
  console.log(indexPath);
}

function runRecordSession(args) {
  const options = parseOptions(args);
  const project = resolveProject(options);
  ensureProjectDirs(project, { records: true, os: true });
  const date = options.date || todayLocal();
  const branchName = String(options.branch || '').trim();
  const sessionId = String(options.sessionId || '').trim();

  if (!branchName || !sessionId) {
    fail('record-session requires --branch and --session-id');
  }

  updateActiveTaskSession(project.osRoot, branchName, sessionId);
  const dayDir = path.join(project.recordsDir, date);
  if (!fs.existsSync(dayDir)) {
    fail(`Date directory not found: ${dayDir}`);
  }
  writeDayIndex(dayDir, date, project.osRoot);
  console.log(path.join(dayDir, 'index.md'));
}

function runConfig(args) {
  const options = parseOptions(args.slice(1));
  const subcommand = args[0];
  const project = resolveProject(options);

  if (subcommand === 'show' || !subcommand) {
    console.log(JSON.stringify({
      osRoot: project.osRoot,
      configPath: project.configPath,
      recordsDir: project.recordsDir || null,
      codeDir: project.codeDir || null,
      defaultRepo: project.defaultRepo || null,
      hooks: project.hooks,
    }, null, 2));
    return;
  }

  if (subcommand === 'init') {
    ensureProjectDirs(project, { os: true });
    if (fs.existsSync(project.configPath) && !options.force) {
      fail(`Config already exists: ${project.configPath}`);
    }

    const payload = {
      recordsDir: options.recordsDir,
      codeDir: options.codeDir,
      defaultRepo: options.defaultRepo || '',
      hooks: {
        onCodeTabOpen: options.hookOnCodeTabOpen || '',
        onClean: options.hookOnClean || '',
      },
    };
    if (!payload.recordsDir || !payload.codeDir) {
      fail('config init requires --records-dir and --code-dir');
    }
    fs.writeFileSync(project.configPath, `${JSON.stringify(payload, null, 2)}\n`, 'utf8');
    console.log(project.configPath);
    return;
  }

  fail(`Unsupported config command: ${subcommand}`);
}

function parseOptions(args) {
  const options = { _: [] };
  for (let index = 0; index < args.length; index += 1) {
    const token = args[index];
    if (token === '--date') {
      options.date = args[++index];
      continue;
    }
    if (token === '--count') {
      options.count = args[++index];
      continue;
    }
    if (token === '--socket') {
      options.socket = args[++index];
      continue;
    }
    if (token === '--dry-run') {
      options.dryRun = true;
      continue;
    }
    if (token === '--all') {
      options.all = true;
      continue;
    }
    if (token === '--no-summary') {
      options.noSummary = true;
      continue;
    }
    if (token === '--no-carry-active') {
      options.noCarryActive = true;
      continue;
    }
    if (token === '--worktree') {
      options.worktree = args[++index];
      continue;
    }
    if (token === '--repo') {
      options.repo = args[++index];
      continue;
    }
    if (token === '--branch') {
      options.branch = args[++index];
      continue;
    }
    if (token === '--slug') {
      options.slug = args[++index];
      continue;
    }
    if (token === '--name') {
      options.name = args[++index];
      continue;
    }
    if (token === '--db-name') {
      options.dbName = args[++index];
      continue;
    }
    if (token === '--test-db-name') {
      options.testDbName = args[++index];
      continue;
    }
    if (token === '--app-port') {
      options.appPort = args[++index];
      continue;
    }
    if (token === '--test-app-port') {
      options.testAppPort = args[++index];
      continue;
    }
    if (token === '--inspect-port') {
      options.inspectPort = args[++index];
      continue;
    }
    if (token === '--rerun-launched') {
      options.rerunLaunched = true;
      continue;
    }
    if (token === '--records-dir') {
      options.recordsDir = args[++index];
      continue;
    }
    if (token === '--default-repo') {
      options.defaultRepo = args[++index];
      continue;
    }
    if (token === '--os-root') {
      options.osRoot = args[++index];
      continue;
    }
    if (token === '--code-dir') {
      options.codeDir = args[++index];
      continue;
    }
    if (token === '--hook-on-code-tab-open') {
      options.hookOnCodeTabOpen = args[++index];
      continue;
    }
    if (token === '--hook-on-clean') {
      options.hookOnClean = args[++index];
      continue;
    }
    if (token === '--force') {
      options.force = true;
      continue;
    }
    if (token === '--session-id') {
      options.sessionId = args[++index];
      continue;
    }
    options._.push(token);
  }
  return options;
}

function todayLocal() {
  const now = new Date();
  const year = String(now.getFullYear());
  const month = String(now.getMonth() + 1).padStart(2, '0');
  const day = String(now.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function nextTaskFile(dayDir) {
  const entries = fs
    .readdirSync(dayDir)
    .filter((entry) => /^tasks(?:-\d{2})?\.md$/.test(entry))
    .sort();

  if (!entries.length) {
    return path.join(dayDir, 'tasks.md');
  }

  let number = 2;
  while (true) {
    const candidate = `tasks-${String(number).padStart(2, '0')}.md`;
    const candidatePath = path.join(dayDir, candidate);
    if (!fs.existsSync(candidatePath)) {
      return candidatePath;
    }
    number += 1;
  }
}

function tasksDir(dayDir) {
  return path.join(dayDir, 'tasks');
}

function createTaskCards({ dayDir, startIndex, count, activeTasks, defaultRepo, defaultBaseBranch }) {
  const createdFiles = [];
  for (let offset = 0; offset < count; offset += 1) {
    const index = startIndex + offset;
    const activeTask = activeTasks[index - 1];
    const filename = `${String(index).padStart(2, '0')}-${slugify(activeTask?.name || `Task ${index}`, index)}.md`;
    const filePath = path.join(tasksDir(dayDir), filename);
    if (fs.existsSync(filePath)) {
      continue;
    }
    fs.writeFileSync(filePath, buildTaskCard(index, activeTask, defaultRepo, defaultBaseBranch), 'utf8');
    createdFiles.push(filePath);
  }
  return createdFiles;
}

function buildTaskCard(index, activeTask, defaultRepo, defaultBaseBranch) {
  return [
    '---',
    `name: ${yamlScalar(activeTask?.name || `Task ${index}`)}`,
    `status: ${yamlScalar(activeTask?.status || 'todo')}`,
    `workdir: ${yamlScalar(activeTask?.repo || defaultRepo)}`,
    `baseBranch: ${yamlScalar(activeTask?.baseBranch || defaultBaseBranch)}`,
    `newBranch: ${yamlScalar(activeTask?.newBranch || '')}`,
    'hooks:',
    ...formatTaskHookEvents(activeTask?.hookEvents).map((event) => `  - ${event}`),
    '---',
    '',
    '```prompt',
    normalizePromptContent(activeTask?.prompt || ''),
    '```',
    '',
  ].join('\n');
}

function resolveDefaultTaskFile(dateArg, recordsDir) {
  const date = dateArg || todayLocal();
  const dayDir = path.join(recordsDir, date);
  if (!fs.existsSync(dayDir)) {
    fail(`Date directory not found: ${dayDir}`);
  }

  const indexPath = path.join(dayDir, 'index.md');
  if (fs.existsSync(indexPath)) {
    return indexPath;
  }
  fail(`index.md not found in ${dayDir}. Run \`mw sync --date ${date}\`.`);
}

function parseTaskFile(content, filePath, project) {
  if (path.basename(filePath) === 'index.md') {
    return parseTaskCardsFromDayDir(path.dirname(filePath), project);
  }
  if (path.dirname(filePath).endsWith(`${path.sep}tasks`)) {
    return parseSingleTaskCard(content, filePath, project);
  }
  throw new Error(`Unsupported task file format: ${filePath}`);
}

function inferDayDirFromTaskPath(filePath) {
  const resolved = path.resolve(filePath);
  if (path.basename(resolved) === 'index.md') {
    return path.dirname(resolved);
  }
  if (path.dirname(resolved).endsWith(`${path.sep}tasks`)) {
    return path.dirname(path.dirname(resolved));
  }
  return '';
}

function parseTaskCardsFromDayDir(dayDir, project) {
  const dateMatch = dayDir.match(/(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : todayLocal();
  const codeDayDir = path.join(project.codeDir, date);
  const activeByBranch = new Map(readActiveTasks(project.osRoot).map((task) => [task.newBranch, task]));
  const tasks = [];
  const files = listTaskCardFiles(dayDir);

  for (const filePath of files) {
    const content = fs.readFileSync(filePath, 'utf8');
    const parsed = parseTaskCard(content, filePath);
    if (isTaskRunnable(parsed.task)) {
      const activeTask = activeByBranch.get(parsed.task.newBranch || '');
      tasks.push({
        ...parsed.task,
        sessionId: activeTask?.sessionId || '',
      });
    }
  }

  return { date, recordsDayDir: dayDir, codeDayDir, osRoot: project.osRoot, defaultRepo: project.defaultRepo || '', tasks };
}

function parseSingleTaskCard(content, filePath, project) {
  const dayDir = path.dirname(path.dirname(filePath));
  const dateMatch = dayDir.match(/(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : todayLocal();
  const codeDayDir = path.join(project.codeDir, date);
  const parsed = parseTaskCard(content, filePath);
  const activeByBranch = new Map(readActiveTasks(project.osRoot).map((task) => [task.newBranch, task]));
  const activeTask = activeByBranch.get(parsed.task.newBranch || '');
  return {
    date,
    recordsDayDir: dayDir,
    codeDayDir,
    osRoot: project.osRoot,
    defaultRepo: project.defaultRepo || '',
    tasks: isTaskRunnable(parsed.task) ? [{
      ...parsed.task,
      sessionId: activeTask?.sessionId || '',
    }] : [],
  };
}

function parseTaskCard(content, filePath) {
  const fields = parseFrontMatter(content);
  const prompt = normalizePromptContent(parsePrompt(content));
  const index = inferTaskIndex(filePath, fields.name);
  const status = normalizeTaskStatus(fields.status || 'todo');
  return {
    task: {
      index,
      name: fields.name || `Task ${index}`,
      status,
      repo: fields.workdir || '',
      baseBranch: fields.baseBranch || '',
      newBranch: fields.newBranch || '',
      hookEvents: parseTaskHookEvents(fields.hooks),
      prompt: prompt.trim(),
      taskFilePath: filePath,
    },
  };
}

function normalizeTaskStatus(value) {
  const status = String(value || 'todo').trim().toLowerCase();
  if (status === 'doing') {
    return 'doing';
  }
  if (status === 'done') {
    return 'done';
  }
  return 'todo';
}

function normalizePromptContent(value) {
  const text = String(value || '').trim();
  if (text === 'Fill the prompt for this task.') {
    return '';
  }
  return text;
}

function isTaskRunnable(task) {
  return task.status !== 'done' && !!String(task.prompt || '').trim();
}

function defaultTaskHookEvents() {
  return ['onCodeTabOpen', 'onClean'];
}

function parseTaskHookEvents(raw) {
  if (!raw || !String(raw).trim()) {
    return defaultTaskHookEvents();
  }
  return String(raw)
    .split(',')
    .map((item) => item.trim())
    .filter(Boolean);
}

function formatTaskHookEvents(events) {
  return Array.isArray(events) && events.length ? events : defaultTaskHookEvents();
}

function taskAllowsHook(task, eventName) {
  const events = Array.isArray(task.hookEvents) && task.hookEvents.length
    ? task.hookEvents
    : defaultTaskHookEvents();
  return events.includes(eventName);
}

function inferTaskIndex(filePath, fallbackName) {
  const base = path.basename(filePath);
  const match = base.match(/^(\d+)/);
  if (match) {
    return Number(match[1]);
  }
  const fallbackMatch = String(fallbackName || '').match(/(\d+)/);
  return fallbackMatch ? Number(fallbackMatch[1]) : 1;
}

function listTaskCardFiles(dayDir) {
  const dirPath = tasksDir(dayDir);
  if (!fs.existsSync(dirPath)) {
    return [];
  }
  return fs.readdirSync(dirPath)
    .filter((entry) => /^\d{2}-.*\.md$/.test(entry))
    .sort()
    .map((entry) => path.join(dirPath, entry));
}

function writeDayIndex(dayDir, date, osRoot) {
  ensureDir(tasksDir(dayDir));
  const files = listTaskCardFiles(dayDir);
  const activeTasks = readActiveTasks(osRoot);
  const activeByBranch = new Map(activeTasks.map((task) => [task.newBranch, task]));
  const activeBranches = new Set(activeTasks.map((task) => task.newBranch));
  const entries = files.map((filePath) => {
    const parsed = parseTaskCard(fs.readFileSync(filePath, 'utf8'), filePath);
    const task = parsed.task;
    const activeTask = activeByBranch.get(task.newBranch || '');
    const status = task.status === 'done'
      ? 'done'
      : !task.prompt
      ? 'draft'
      : activeBranches.has(task.newBranch)
        ? 'active'
        : task.status === 'doing'
          ? 'doing'
          : 'todo';
    return {
      index: task.index,
      name: task.name,
      status,
      branch: task.newBranch || '(auto)',
      sessionId: activeTask?.sessionId || '',
      file: path.relative(dayDir, filePath),
    };
  });

  const content = buildDayIndex(date, entries);
  const indexPath = path.join(dayDir, 'index.md');
  fs.writeFileSync(indexPath, content, 'utf8');
  return indexPath;
}

function buildDayIndex(date, entries) {
  const lines = [
    `# Daily Workflow ${date}`,
    '',
    '## Tasks',
    '',
  ];

  if (!entries.length) {
    lines.push('- No task cards yet.');
  } else {
    for (const entry of entries) {
      lines.push(`- ${String(entry.index).padStart(2, '0')} | ${entry.status} | ${entry.name} | ${entry.branch} | ${entry.sessionId || '-'} | ${entry.file}`);
    }
  }

  lines.push('');
  lines.push('## Notes');
  lines.push('');
  lines.push('- Edit files in `tasks/` and run `mw sync --date YYYY-MM-DD` to rebuild this index.');
  lines.push('');
  return lines.join('\n');
}

function activeStatePath(rootDir) {
  return path.join(rootDir, ACTIVE_STATE_FILE);
}

function readActiveTasks(rootDir) {
  const statePath = activeStatePath(rootDir);
  if (!fs.existsSync(statePath)) {
    return [];
  }

  const raw = fs.readFileSync(statePath, 'utf8').trim();
  if (!raw) {
    return [];
  }

  let parsed;
  try {
    parsed = JSON.parse(raw);
  } catch (error) {
    throw new Error(`Failed to parse ${statePath}`);
  }

  const tasks = Array.isArray(parsed.tasks) ? parsed.tasks : [];
  return tasks.filter((task) => {
    return task
      && typeof task.name === 'string'
      && typeof task.repo === 'string'
      && typeof task.newBranch === 'string'
      && typeof task.prompt === 'string';
  });
}

function writeActiveTasks(rootDir, tasks) {
  const statePath = activeStatePath(rootDir);
  const payload = {
    updatedAt: new Date().toISOString(),
    tasks,
  };
  fs.writeFileSync(statePath, `${JSON.stringify(payload, null, 2)}\n`, 'utf8');
}

function upsertActiveTasks(rootDir, tasks, date) {
  const existing = readActiveTasks(rootDir);
  const byBranch = new Map(existing.map((task) => [task.newBranch, task]));

  for (const task of tasks) {
    byBranch.set(task.newBranch, {
      name: task.name,
      repo: task.repo,
      baseBranch: task.baseBranch,
      newBranch: task.newBranch,
      hookEvents: task.hookEvents,
      sessionId: task.sessionId || '',
      prompt: task.prompt,
      lastDate: date,
    });
  }

  writeActiveTasks(rootDir, Array.from(byBranch.values()));
}

function removeActiveTasks(rootDir, branchNames) {
  const existing = readActiveTasks(rootDir);
  const blocked = new Set(branchNames);
  const nextTasks = existing.filter((task) => !blocked.has(task.newBranch));
  writeActiveTasks(rootDir, nextTasks);
}

function updateActiveTaskSummary(rootDir, branchName, reportMarkdown) {
  const existing = readActiveTasks(rootDir);
  let changed = false;
  const nextTasks = existing.map((task) => {
    if (task.newBranch !== branchName) {
      return task;
    }
    changed = true;
    return {
      ...task,
      lastSummary: extractSection(reportMarkdown, '### Summary'),
      lastNext: extractSection(reportMarkdown, '### Next'),
      lastReportedAt: new Date().toISOString(),
    };
  });

  if (changed) {
    writeActiveTasks(rootDir, nextTasks);
  }
}

function updateActiveTaskSession(rootDir, branchName, sessionId) {
  const existing = readActiveTasks(rootDir);
  let changed = false;
  const nextTasks = existing.map((task) => {
    if (task.newBranch !== branchName) {
      return task;
    }
    changed = true;
    return {
      ...task,
      sessionId,
    };
  });

  if (changed) {
    writeActiveTasks(rootDir, nextTasks);
  }
}

function parseFrontMatter(section) {
  const match = section.match(/^---\n([\s\S]*?)\n---/);
  if (!match) {
    throw new Error('Task card is missing YAML front matter');
  }

  const fields = {};
  let currentListKey = '';
  for (const rawLine of match[1].split('\n')) {
    const line = rawLine.replace(/\r$/, '');
    if (!line.trim()) {
      continue;
    }
    const listItem = line.match(/^\s*-\s*(.+)\s*$/);
    if (listItem && currentListKey) {
      if (!Array.isArray(fields[currentListKey])) {
        fields[currentListKey] = [];
      }
      fields[currentListKey].push(listItem[1].trim());
      continue;
    }
    const kv = line.match(/^([A-Za-z][A-Za-z0-9_]*)\s*:\s*(.*)$/);
    if (!kv) {
      continue;
    }
    const key = kv[1];
    const value = kv[2];
    if (value === '') {
      fields[key] = [];
      currentListKey = key;
    } else {
      fields[key] = stripYamlScalar(value.trim());
      currentListKey = '';
    }
  }
  return fields;
}

function stripYamlScalar(value) {
  if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
    return value.slice(1, -1);
  }
  return value;
}

function yamlScalar(value) {
  const str = String(value ?? '');
  return JSON.stringify(str);
}

function updateTaskCardStatus(filePath, status) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const nextStatus = normalizeTaskStatus(status);
  if (/^status:\s*/m.test(raw)) {
    const updated = raw.replace(/^status:\s*.*$/m, `status: ${yamlScalar(nextStatus)}`);
    fs.writeFileSync(filePath, updated, 'utf8');
    return;
  }
  const updated = raw.replace(/^name:\s*.*$/m, (line) => `${line}\nstatus: ${yamlScalar(nextStatus)}`);
  fs.writeFileSync(filePath, updated, 'utf8');
}

function parsePrompt(section) {
  const match = section.match(/```prompt\s*\n([\s\S]*?)\n```/);
  return match ? match[1] : '';
}

function parseBoolean(value) {
  return ['1', 'true', 'yes', 'y', 'on'].includes(String(value).trim().toLowerCase());
}

function resolveTask(context, task) {
  const repoInput = task.repo || context.defaultRepo || '';
  if (!repoInput) {
    throw new Error(`Task ${task.index} does not specify Workdir and no defaultRepo is configured`);
  }
  const repo = path.resolve(repoInput);
  if (!isGitRepo(repo)) {
    throw new Error(`Not a git repository: ${repo}`);
  }

  const baseBranch = task.baseBranch || detectCurrentBranch(repo);
  if (!baseBranch) {
    throw new Error(`Unable to determine base branch for ${repo}`);
  }

  const slug = slugify(task.name, task.index);
  const newBranch = task.newBranch || `magicwork/${context.date}/${String(task.index).padStart(2, '0')}-${slug}`;
  const worktreeDirName = `${String(task.index).padStart(2, '0')}-${slug}`;
  const expectedWorktreePath = path.join(context.codeDayDir, worktreeDirName);
  const existingWorktreePath = findWorktreePathByBranch(repo, newBranch);
  const worktreePath = existingWorktreePath || expectedWorktreePath;

  return {
    ...task,
    repo,
    slug,
    baseBranch,
    newBranch,
    date: context.date,
    recordsDayDir: context.recordsDayDir,
    osRoot: context.osRoot,
    worktreePath,
  };
}

function resolveCleanTargets(tasks, rawTargets) {
  if (!rawTargets.length) {
    fail('Provide one or more task indexes, worktree directory names, or branch names, or use --all');
  }

  const byIndex = new Map(tasks.map((task) => [String(task.index), task]));
  const byDirName = new Map(tasks.map((task) => [path.basename(task.worktreePath), task]));
  const byBranch = new Map(tasks.map((task) => [task.newBranch, task]));
  const selected = [];
  const seen = new Set();

  for (const rawTarget of rawTargets) {
    const key = String(rawTarget).trim();
    const task = byIndex.get(key) || byDirName.get(key) || byBranch.get(key);
    if (!task) {
      throw new Error(`Unknown clean target: ${rawTarget}`);
    }
    if (seen.has(task.worktreePath)) {
      continue;
    }
    seen.add(task.worktreePath);
    selected.push(task);
  }

  return selected;
}

function taskRecordPath(recordsDir, task) {
  return path.join(recordsDir, RECORDS_DIR, `${slugify(task.newBranch || task.name, task.index)}.md`);
}

function taskSummaryPath(task) {
  return path.join(task.recordsDayDir, 'summaries', `${String(task.index).padStart(2, '0')}-${task.slug}.md`);
}

function codexSessionsRoot() {
  return path.join(process.env.HOME || '', '.codex', 'sessions');
}

function buildTaskConversationContext(task) {
  if (!task.sessionId) {
    return null;
  }

  const rolloutPath = findCodexRolloutPath(task.sessionId);
  if (!rolloutPath || !fs.existsSync(rolloutPath)) {
    return null;
  }

  const readablePath = path.join('/tmp', `magicwork-conversation-${task.sessionId}.md`);
  fs.writeFileSync(readablePath, renderCodexConversationMarkdown(task.sessionId, rolloutPath), 'utf8');
  return { sessionId: task.sessionId, rolloutPath, readablePath };
}

function hasConversationContext(task) {
  if (!task.sessionId) {
    return false;
  }
  const rolloutPath = findCodexRolloutPath(task.sessionId);
  return !!(rolloutPath && fs.existsSync(rolloutPath));
}

function cleanupConversationContext(context) {
  if (context?.readablePath && fs.existsSync(context.readablePath)) {
    fs.unlinkSync(context.readablePath);
  }
}

function findCodexRolloutPath(sessionId) {
  const rootDir = codexSessionsRoot();
  if (!sessionId || !fs.existsSync(rootDir)) {
    return '';
  }
  const targetSuffix = `-${sessionId}.jsonl`;
  const stack = [rootDir];

  while (stack.length) {
    const current = stack.pop();
    const entries = fs.readdirSync(current, { withFileTypes: true });
    for (const entry of entries) {
      const fullPath = path.join(current, entry.name);
      if (entry.isDirectory()) {
        stack.push(fullPath);
        continue;
      }
      if (entry.isFile() && entry.name.endsWith(targetSuffix)) {
        return fullPath;
      }
    }
  }

  return '';
}

function renderCodexConversationMarkdown(sessionId, rolloutPath) {
  const lines = [
    `# Codex Conversation ${sessionId}`,
    '',
    `- Rollout: ${rolloutPath}`,
    '',
  ];
  const raw = fs.readFileSync(rolloutPath, 'utf8');
  const entries = raw.split('\n').filter(Boolean);

  for (const line of entries) {
    let item;
    try {
      item = JSON.parse(line);
    } catch (error) {
      continue;
    }

    if (item.type === 'response_item' && item.payload?.type === 'message') {
      const role = item.payload.role || 'unknown';
      const phase = item.payload.phase ? ` (${item.payload.phase})` : '';
      const text = extractMessageText(item.payload.content || []);
      if (!text) {
        continue;
      }
      lines.push(`## ${role}${phase}`);
      lines.push('');
      lines.push(text);
      lines.push('');
      continue;
    }

    if (item.type === 'response_item' && item.payload?.type === 'function_call') {
      lines.push(`## tool_call ${item.payload.name || 'unknown'}`);
      lines.push('');
      lines.push('```json');
      lines.push(item.payload.arguments || '');
      lines.push('```');
      lines.push('');
      continue;
    }

    if (item.type === 'response_item' && item.payload?.type === 'function_call_output') {
      lines.push(`## tool_output ${item.payload.call_id || ''}`.trim());
      lines.push('');
      lines.push('```text');
      lines.push(String(item.payload.output || '').trim());
      lines.push('```');
      lines.push('');
    }
  }

  return `${lines.join('\n').trim()}\n`;
}

function extractMessageText(content) {
  const parts = [];
  for (const item of content) {
    if (!item || typeof item !== 'object') {
      continue;
    }
    if (typeof item.text === 'string' && item.text.trim()) {
      parts.push(item.text.trim());
    }
  }
  return parts.join('\n\n').trim();
}

function generateTaskSummary(task) {
  const tempOutputPath = path.join('/tmp', `magicwork-summary-${Date.now()}-${process.pid}.md`);
  const conversationContext = buildTaskConversationContext(task);
  const useWorktree = hasUsableWorktree(task);
  const prompt = [
    useWorktree
      ? 'Review the current repository state and the Codex conversation record, then write a concise task summary in Markdown.'
      : 'Review the Codex conversation record only, then write a concise task summary in Markdown.',
    `Task session id: ${task.sessionId || '(missing)'}`,
    conversationContext
      ? `Readable conversation path: ${conversationContext.readablePath}`
      : useWorktree
        ? `No Codex conversation record is available. Continue using only the repository state for ${task.worktreePath}.`
        : 'No Codex conversation record is available.',
    'Use exactly these sections and nothing else:',
    '### Summary',
    '- bullet points only',
    '### Files',
    '- bullet points only, use file paths',
    '### Decisions',
    '- bullet points only',
    '### Next',
    '- bullet points only',
    useWorktree
      ? 'Focus on what was attempted, what changed, validation status, blockers, and what should happen next.'
      : 'Focus on what was attempted, decisions made, validation mentioned in the conversation, blockers, and what should happen next. If files cannot be confirmed from the conversation, say so briefly in the Files section.',
  ].join('\n');

  try {
    const args = [
      'exec',
      '--dangerously-bypass-approvals-and-sandbox',
      '--output-last-message',
      tempOutputPath,
      prompt,
    ];
    if (useWorktree) {
      args.splice(2, 0, '-C', task.worktreePath);
    }
    const result = spawnSync('codex', args, {
      encoding: 'utf8',
    });

    if (result.status !== 0) {
      throw new Error(result.stderr.trim() || `Failed to generate summary for ${task.name}`);
    }

    if (!fs.existsSync(tempOutputPath)) {
      throw new Error(`Summary output was not written for ${task.name}`);
    }

    const markdown = fs.readFileSync(tempOutputPath, 'utf8').trim();
    if (!markdown) {
      throw new Error(`Empty summary output for ${task.name}`);
    }

    return markdown;
  } finally {
    if (fs.existsSync(tempOutputPath)) {
      fs.unlinkSync(tempOutputPath);
    }
    cleanupConversationContext(conversationContext);
  }
}

function generateTaskReport(task) {
  const tempOutputPath = path.join('/tmp', `magicwork-report-${Date.now()}-${process.pid}.md`);
  const conversationContext = buildTaskConversationContext(task);
  const useWorktree = hasUsableWorktree(task);
  const prompt = [
    useWorktree
      ? 'Review the current repository state and the Codex conversation record, then write a concise task progress report in Markdown.'
      : 'Review the Codex conversation record only, then write a concise task progress report in Markdown.',
    `Task session id: ${task.sessionId || '(missing)'}`,
    conversationContext
      ? `Readable conversation path: ${conversationContext.readablePath}`
      : useWorktree
        ? 'No Codex conversation record is available, so rely on repository state only.'
        : 'No Codex conversation record is available.',
    'Use exactly these sections and nothing else:',
    '### Summary',
    '- bullet points only',
    '### Files',
    '- bullet points only, use file paths',
    '### Next',
    '- bullet points only',
    useWorktree
      ? 'Focus on the current worktree status, recent code changes, validation status, blockers, and immediate next steps.'
      : 'Focus on the current progress described in the conversation, mentioned changes, validation status, blockers, and immediate next steps. If files cannot be confirmed from the conversation, say so briefly in the Files section.',
  ].join('\n');

  try {
    const args = [
      'exec',
      '--dangerously-bypass-approvals-and-sandbox',
      '--output-last-message',
      tempOutputPath,
      prompt,
    ];
    if (useWorktree) {
      args.splice(2, 0, '-C', task.worktreePath);
    }
    const result = spawnSync('codex', args, {
      encoding: 'utf8',
    });

    if (result.status !== 0) {
      throw new Error(result.stderr.trim() || `Failed to generate report for ${task.name}`);
    }

    if (!fs.existsSync(tempOutputPath)) {
      throw new Error(`Report output was not written for ${task.name}`);
    }

    const markdown = fs.readFileSync(tempOutputPath, 'utf8').trim();
    if (!markdown) {
      throw new Error(`Empty report output for ${task.name}`);
    }

    return markdown;
  } finally {
    if (fs.existsSync(tempOutputPath)) {
      fs.unlinkSync(tempOutputPath);
    }
    cleanupConversationContext(conversationContext);
  }
}

function appendTaskRecord(recordPath, task, reportMarkdown) {
  const lines = [];

  if (!fs.existsSync(recordPath)) {
    lines.push(`# ${task.name}`);
    lines.push('');
    lines.push(`- Branch: ${task.newBranch}`);
    lines.push(`- Repo: ${task.repo}`);
    lines.push('');
  }

  lines.push(`## ${new Date().toISOString()}`);
  lines.push(`- Worktree: ${task.worktreePath}`);
  lines.push('');
  lines.push(reportMarkdown.trim());
  lines.push('');

  fs.appendFileSync(recordPath, `${lines.join('\n')}\n`, 'utf8');
}

function appendTaskSummary(summaryPath, task, summaryMarkdown) {
  const lines = [];

  if (!fs.existsSync(summaryPath)) {
    lines.push(`# ${task.name}`);
    lines.push('');
    lines.push(`- Branch: ${task.newBranch}`);
    lines.push(`- Repo: ${task.repo}`);
    lines.push(`- Worktree: ${task.worktreePath}`);
    lines.push(`- SessionId: ${task.sessionId || ''}`);
    lines.push('');
  }

  lines.push(`## ${new Date().toISOString()}`);
  lines.push('');
  lines.push(summaryMarkdown.trim());
  lines.push('');

  ensureDir(path.dirname(summaryPath));
  fs.appendFileSync(summaryPath, `${lines.join('\n')}\n`, 'utf8');
}

function extractSection(markdown, heading) {
  const pattern = new RegExp(`${escapeRegExp(heading)}\\n([\\s\\S]*?)(?:\\n### |$)`);
  const match = markdown.match(pattern);
  return match ? match[1].trim() : '';
}

function hasUsableWorktree(task) {
  return !!(task.worktreePath && fs.existsSync(task.worktreePath) && isGitRepo(task.worktreePath));
}

function hasSummaryContext(task) {
  return hasUsableWorktree(task) || hasConversationContext(task);
}

function escapeRegExp(value) {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function ensureWorktree(task) {
  if (isGitRepo(task.worktreePath)) {
    return false;
  }

  if (fs.existsSync(task.worktreePath) && fs.readdirSync(task.worktreePath).length > 0) {
    throw new Error(`Worktree path exists and is not empty: ${task.worktreePath}`);
  }

  ensureDir(task.worktreePath);

  const branchAlreadyExists = branchExists(task.repo, task.newBranch);

  const args = ['worktree', 'add'];
  if (branchAlreadyExists) {
    args.push(task.worktreePath, task.newBranch);
  } else {
    args.push('-b', task.newBranch, task.worktreePath, task.baseBranch);
  }

  const result = runGit(task.repo, args, { allowFailure: true });
  if (result.status !== 0) {
    throw new Error(result.stderr.trim() || `Failed to create worktree for ${task.name}`);
  }

  return true;
}

function removeWorktreeAndBranch(task, logger = () => {}) {
  if (hasUsableWorktree(task)) {
    logger(`clean: git worktree remove --force ${task.worktreePath}`);
    const removeResult = runGit(task.repo, ['worktree', 'remove', '--force', task.worktreePath], {
      allowFailure: true,
    });
    if (removeResult.status !== 0) {
      throw new Error(removeResult.stderr.trim() || `Failed to remove worktree for ${task.name}`);
    }
    logger(`clean: removed worktree ${task.worktreePath}`);
  } else {
    logger(`clean: skip worktree remove, path not an active git worktree: ${task.worktreePath}`);
  }

  pruneStaleWorktrees(task.repo, logger);

  if (branchExists(task.repo, task.newBranch)) {
    logger(`clean: git branch -D ${task.newBranch}`);
    const branchResult = runGit(task.repo, ['branch', '-D', task.newBranch], {
      allowFailure: true,
    });
    if (branchResult.status !== 0) {
      throw new Error(branchResult.stderr.trim() || `Failed to delete branch for ${task.name}`);
    }
    logger(`clean: removed branch ${task.newBranch}`);
  } else {
    logger(`clean: skip branch delete, branch not found: ${task.newBranch}`);
  }
}

function logCleanStep(message) {
  console.log(message);
}

function findWorktreePathByBranch(repo, branchName) {
  const result = runGit(repo, ['worktree', 'list', '--porcelain'], { allowFailure: true });
  if (result.status !== 0) {
    throw new Error(result.stderr.trim() || `Failed to list worktrees for ${repo}`);
  }

  const lines = result.stdout.split('\n');
  let currentWorktree = '';
  let currentBranch = '';
  let currentPrunable = false;

  for (const line of [...lines, '']) {
    if (!line.trim()) {
      if (currentWorktree && currentBranch === `refs/heads/${branchName}` && !currentPrunable) {
        return currentWorktree;
      }
      currentWorktree = '';
      currentBranch = '';
      currentPrunable = false;
      continue;
    }

    if (line.startsWith('worktree ')) {
      currentWorktree = line.slice('worktree '.length).trim();
      continue;
    }

    if (line.startsWith('branch ')) {
      currentBranch = line.slice('branch '.length).trim();
      continue;
    }

    if (line.startsWith('prunable ')) {
      currentPrunable = true;
    }
  }

  return '';
}

function pruneStaleWorktrees(repo, logger = () => {}) {
  logger('clean: git worktree prune');
  const pruneResult = runGit(repo, ['worktree', 'prune'], {
    allowFailure: true,
  });
  if (pruneResult.status !== 0) {
    throw new Error(pruneResult.stderr.trim() || `Failed to prune worktrees for ${repo}`);
  }
}

function launchKittyTab(task, socketAddress, project, { sendPrompt = true, trigger = 'run' } = {}) {
  const windowTitle = task.name;
  const codexTabTitle = `${task.name} / codex`;
  const viTabTitle = `${task.name} / vi`;
  const codeTabTitle = `${task.name} / code`;
  const codexBaseArgs = [
    '--dangerously-bypass-approvals-and-sandbox',
    '-c',
    'shell_environment_policy.inherit=all',
    '-c',
    `notify=["python3","${CODEX_NOTIFY_SCRIPT}"]`,
    '-C',
    task.worktreePath,
  ];
  const taskEnv = {
    MW_TASK_NAME: task.name,
    MW_TASK_INDEX: String(task.index),
    MW_TASK_BRANCH: task.newBranch,
    MW_TASK_REPO: task.repo,
    MW_TASK_WORKTREE: task.worktreePath,
    MW_TASK_FILE: task.taskFilePath || '',
    MW_TASK_DATE: task.date,
    MW_TRIGGER: trigger,
    MW_OS_ROOT: task.osRoot || '',
    MW_RECORDS_DAY_DIR: task.recordsDayDir || '',
    MW_CODE_DIR: project.codeDir || '',
  };
  const shouldResumeSession = trigger === 'restore' && !!task.sessionId;
  const codexCommand = shouldResumeSession
    ? [
      CODEX_SESSION_SCRIPT,
      'codex',
      'resume',
      ...codexBaseArgs,
      task.sessionId,
    ]
    : [
      CODEX_SESSION_SCRIPT,
      'codex',
      ...codexBaseArgs,
    ];
  if (sendPrompt && task.prompt) {
    codexCommand.push(task.prompt);
  }
  const codexWindowId = launchKittyWindow(
    socketAddress,
    {
      type: 'os-window',
      title: codexTabTitle,
      tabTitle: codexTabTitle,
      cwd: task.worktreePath,
      hold: true,
      keepFocus: true,
      osWindowTitle: windowTitle,
      watcher: CODEX_WATCHER_SCRIPT,
      env: {
        MW_ROLE: 'codex',
        MW_CODEX_CWD: task.worktreePath,
        MW_TAB_TITLE: codexTabTitle,
        MW_SOCKET: socketAddress,
        MW_INITIAL_PROMPT: sendPrompt ? task.prompt : '',
        MW_HOOK_EVENT: trigger === 'run' && project.hooks.onCodeTabOpen && taskAllowsHook(task, 'onCodeTabOpen') ? 'onCodeTabOpen' : '',
        MW_MAGICWORK_BIN: path.join(__dirname, 'magicwork'),
        MW_REGISTER_SESSION_SCRIPT: REGISTER_SESSION_SCRIPT,
        ...taskEnv,
      },
    },
    codexCommand,
    task.name,
  );

  const codexWindowIdText = String(codexWindowId);
  launchKittyWindow(
    socketAddress,
    {
      type: 'tab',
      title: 'vi',
      tabTitle: viTabTitle,
      cwd: task.worktreePath,
      hold: true,
      match: `window_id:${codexWindowIdText}`,
      keepFocus: true,
    },
    [defaultShell(), '-lic', buildEditorLaunchCommand(task.worktreePath)],
    task.name,
  );

  launchKittyWindow(
    socketAddress,
    {
      type: 'tab',
      title: 'code',
      tabTitle: codeTabTitle,
      cwd: task.worktreePath,
      hold: true,
      match: `window_id:${codexWindowIdText}`,
      keepFocus: true,
      env: {
        MW_ROLE: 'code',
        MW_HOOK_EVENT: trigger === 'run' && project.hooks.onCodeTabOpen && taskAllowsHook(task, 'onCodeTabOpen') ? 'onCodeTabOpen' : '',
        ...taskEnv,
      },
    },
    buildCodeTabCommand(task, project, trigger),
    task.name,
  );
}

function launchKittyWindow(socketAddress, options, command, taskName) {
  const args = ['@', '--to', socketAddress, 'launch'];
  if (options.match) {
    args.push('--match', options.match);
  }
  args.push(`--type=${options.type}`);
  if (options.keepFocus) {
    args.push('--dont-take-focus');
  }
  args.push('--env', `PATH=${buildKittyPathEnv()}`);
  args.push('--env', `SHELL=${defaultShell()}`);
  for (const [key, value] of Object.entries(options.env || {})) {
    args.push('--env', `${key}=${value}`);
  }
  args.push('--title', options.title);
  args.push('--tab-title', options.tabTitle);
  args.push('--cwd', options.cwd);
  if (options.hold) {
    args.push('--hold');
  }
  if (options.osWindowTitle) {
    args.push('--os-window-title', options.osWindowTitle);
  }
  if (options.watcher) {
    args.push('--watcher', options.watcher);
  }
  args.push(...command);

  const result = spawnSync('kitty', args, { encoding: 'utf8' });
  if (result.status !== 0) {
    throw new Error(result.stderr.trim() || `Failed to launch kitty window for ${taskName}`);
  }

  return result.stdout.trim();
}

function buildCodeTabCommand(task, project, trigger) {
  const hookPath = project.hooks.onCodeTabOpen;
  if (!hookPath || trigger !== 'run' || !taskAllowsHook(task, 'onCodeTabOpen')) {
    return [defaultShell(), '-il'];
  }
  if (!fs.existsSync(hookPath)) {
    throw new Error(`Configured hook not found: ${hookPath}`);
  }

  return [defaultShell(), '-ilc', buildHookShellCommand(hookPath, 'onCodeTabOpen')];
}

function buildHookShellCommand(hookPath, eventName) {
  const shellPath = shellEscape(defaultShell());
  return `${shellEscape(hookPath)} ${shellEscape(eventName)}; exec ${shellPath} -il`;
}

function runLifecycleHook(hookPath, eventName, task, { logger = () => {} } = {}) {
  if (!hookPath) {
    return;
  }
  if (!fs.existsSync(hookPath)) {
    throw new Error(`Configured hook not found: ${hookPath}`);
  }

  logger(`hook: ${eventName} ${hookPath}`);
  const result = spawnSync(hookPath, [eventName], {
    encoding: 'utf8',
    env: {
      ...process.env,
      MW_HOOK_EVENT: eventName,
      MW_TASK_NAME: task.name,
      MW_TASK_INDEX: String(task.index),
      MW_TASK_REPO: task.repo,
      MW_TASK_BRANCH: task.newBranch,
      MW_TASK_WORKTREE: task.worktreePath,
      MW_TASK_FILE: task.taskFilePath || '',
      MW_TASK_DATE: task.date || '',
      MW_TASK_SLUG: task.slug || '',
      MW_OS_ROOT: task.osRoot || '',
      MW_RECORDS_DAY_DIR: task.recordsDayDir || '',
    },
    stdio: 'inherit',
  });

  if (result.status !== 0) {
    throw new Error(`Hook failed: ${eventName} (${hookPath})`);
  }
}

function resolveKittySocket(explicitSocket) {
  if (explicitSocket) {
    return explicitSocket;
  }

  if (process.env.KITTY_LISTEN_ON) {
    return process.env.KITTY_LISTEN_ON;
  }

  return DEFAULT_SOCKET;
}

function ensureKittyServer(socketAddress) {
  if (kittyServerReady(socketAddress)) {
    return;
  }

  spawn('kitty', [
    '--single-instance',
    '--instance-group',
    'magicwork',
    '--listen-on',
    socketAddress,
    '-o',
    'allow_remote_control=yes',
  ], {
    detached: true,
    stdio: 'ignore',
  }).unref();

  const deadline = Date.now() + 8000;
  while (Date.now() < deadline) {
    sleep(250);
    if (kittyServerReady(socketAddress)) {
      return;
    }
  }

  throw new Error(`Kitty remote control is not ready on ${socketAddress}`);
}

function kittyServerReady(socketAddress) {
  const result = spawnSync('kitty', ['@', '--to', socketAddress, 'ls'], {
    encoding: 'utf8',
  });
  return result.status === 0;
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

function defaultShell() {
  return process.env.SHELL || '/bin/zsh';
}

function buildKittyPathEnv() {
  const segments = [];
  const seen = new Set();

  for (const value of [
    process.env.PATH || '',
    '/opt/homebrew/bin',
    '/opt/homebrew/opt/libpq/bin',
    '/usr/local/bin',
    '/usr/bin',
    '/bin',
    '/usr/sbin',
    '/sbin',
  ]) {
    for (const entry of String(value).split(path.delimiter)) {
      if (!entry || seen.has(entry)) {
        continue;
      }
      seen.add(entry);
      segments.push(entry);
    }
  }

  return segments.join(path.delimiter);
}

function buildEditorLaunchCommand(targetDir) {
  const shellDir = shellEscape(targetDir);
  const nvimPath = resolveExecutable('nvim');
  if (nvimPath) {
    return `cd ${shellDir} && exec ${shellEscape(nvimPath)}`;
  }

  return `cd ${shellDir} && exec vi`;
}

function resolveExecutable(binary) {
  const result = spawnSync('which', [binary], { encoding: 'utf8' });
  if (result.status !== 0) {
    return '';
  }
  return result.stdout.trim();
}

function shellEscape(value) {
  return `'${String(value).replace(/'/g, `'\\''`)}'`;
}

function detectCurrentBranch(repo) {
  const result = runGit(repo, ['branch', '--show-current'], { allowFailure: true });
  if (result.status !== 0) {
    return '';
  }
  return result.stdout.trim();
}

function isGitRepo(targetPath) {
  const result = spawnSync('git', ['-C', targetPath, 'rev-parse', '--is-inside-work-tree'], {
    encoding: 'utf8',
  });
  return result.status === 0 && result.stdout.trim() === 'true';
}

function runGit(repo, args, { allowFailure = false } = {}) {
  const result = spawnSync('git', ['-C', repo, ...args], {
    encoding: 'utf8',
  });

  if (!allowFailure && result.status !== 0) {
    throw new Error(result.stderr.trim() || `git ${args.join(' ')} failed in ${repo}`);
  }

  return result;
}

function branchExists(repo, branchName) {
  return runGit(repo, ['show-ref', '--verify', '--quiet', `refs/heads/${branchName}`], {
    allowFailure: true,
  }).status === 0;
}

function slugify(input, index) {
  const slug = String(input)
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 40);

  return slug || `task-${index}`;
}

function ensureDir(targetPath) {
  fs.mkdirSync(targetPath, { recursive: true });
}

function resolveProject(options = {}) {
  const osRoot = resolveOsRoot(options.osRoot);
  const configPath = path.join(osRoot, CONFIG_FILE);
  const fileConfig = readProjectConfig(configPath);
  const rawRecordsDir = options.recordsDir || fileConfig.recordsDir || '';
  const rawCodeDir = options.codeDir || fileConfig.codeDir || '';
  const rawDefaultRepo = options.defaultRepo || fileConfig.defaultRepo || '';
  const rawHooks = {
    onCodeTabOpen: options.hookOnCodeTabOpen || fileConfig.hooks?.onCodeTabOpen || '',
    onClean: options.hookOnClean || fileConfig.hooks?.onClean || '',
  };

  return {
    osRoot,
    configPath,
    recordsDir: rawRecordsDir ? resolveConfiguredPath(rawRecordsDir, osRoot) : '',
    codeDir: rawCodeDir ? resolveConfiguredPath(rawCodeDir, osRoot) : '',
    defaultRepo: rawDefaultRepo ? resolveConfiguredPath(rawDefaultRepo, osRoot) : '',
    hooks: {
      onCodeTabOpen: rawHooks.onCodeTabOpen ? resolveConfiguredPath(rawHooks.onCodeTabOpen, osRoot) : '',
      onClean: rawHooks.onClean ? resolveConfiguredPath(rawHooks.onClean, osRoot) : '',
    },
  };
}

function resolveOsRoot(explicitOsRoot) {
  return resolveUserPath(
    explicitOsRoot
      || process.env.MAGICWORK_OS_ROOT
      || path.join(process.env.HOME || '', '.config', 'magicwork'),
  );
}

function resolveConfiguredPath(targetPath, baseDir) {
  const expanded = resolveUserPath(targetPath);
  return path.isAbsolute(expanded) ? expanded : path.resolve(baseDir, expanded);
}

function resolveUserPath(targetPath) {
  const raw = String(targetPath || '');
  if (raw === '~') {
    return process.env.HOME || raw;
  }
  if (raw.startsWith('~/')) {
    return path.join(process.env.HOME || '', raw.slice(2));
  }
  return raw;
}

function ensureProjectDirs(project, flags = {}) {
  if (flags.os) {
    ensureDir(project.osRoot);
  }
  if (flags.records) {
    if (!project.recordsDir) {
      fail('recordsDir is not configured. Run `mw config init --records-dir ... --code-dir ...` first.');
    }
    ensureDir(project.recordsDir);
  }
  if (flags.code) {
    if (!project.codeDir) {
      fail('codeDir is not configured. Run `mw config init --records-dir ... --code-dir ...` first.');
    }
    ensureDir(project.codeDir);
  }
}

function readProjectConfig(configPath) {
  if (!fs.existsSync(configPath)) {
    return {};
  }

  let parsed;
  try {
    parsed = JSON.parse(fs.readFileSync(configPath, 'utf8'));
  } catch (error) {
    throw new Error(`Failed to parse ${configPath}`);
  }

  return parsed && typeof parsed === 'object' ? parsed : {};
}

function printHelp() {
  console.log([
    'magicwork',
    '',
    'Commands:',
    '  init [--date YYYY-MM-DD]     Create a daily Markdown task template',
    '  add [--date YYYY-MM-DD]      Append more task cards for the day',
    '  run [file] [--date ...]      Create worktrees and launch task workspaces',
    '  sync [--date YYYY-MM-DD]     Rebuild index.md from task cards',
    '  restore [targets...]         Reopen active task workspaces without init or prompt',
    '  clean [file] [targets...]    Remove worktrees and their branches',
    '  finish [file] [targets...]   Summarize, mark done, and clean tasks',
    '  report [file] [targets...]   Summarize task progress into records/',
    '  config [show|init]           Show or create config in osRoot',
    '',
    'Examples:',
    '  mw config show',
    `  mw config init --os-root ~/.config/magicwork --records-dir ~/magicwork/records --code-dir ~/magicwork/code --default-repo /path/to/repo --hook-on-code-tab-open ${EXAMPLE_HOOK_SCRIPT} --hook-on-clean ${EXAMPLE_HOOK_SCRIPT}`,
    '  mw config show',
    '  mw init',
    '  mw init 3',
    '  mw init --count 3',
    '  mw add',
    '  mw add 3',
    '  mw init --no-carry-active',
    '  mw sync --date 2026-04-18',
    '  mw run',
    '  mw run 3',
    '  mw run 1 3 5',
    '  mw run --rerun-launched',
    '  mw restore',
    '  mw restore 1 3',
    '  mw restore task-3512',
    '  mw run --dry-run',
    '  mw clean 1 3',
    '  mw finish 1 3',
    '  mw finish 1 --no-summary',
    '  mw clean 01-task-1',
    '  mw clean magicwork/2026-04-17/01-task-1',
    '  mw clean --all',
    '  mw report 1',
    '  mw report --all',
    '  mw run ~/magicwork/records/2026-04-18/index.md',
  ].join('\n'));
}

function fail(message) {
  console.error(`Error: ${message}`);
  process.exit(1);
}
